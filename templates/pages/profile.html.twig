{% extends 'base.html.twig' %}

{% block title %}Mon Profil{% endblock %}

{% block content %}
<div class="product-detail" style="max-width:500px;">
    <h1>👤 Mon Profil</h1>
    <p><strong>Nom :</strong> {{ app.user.name }}</p>
    <p style="margin-top:10px;"><strong>Email :</strong> {{ app.user.email }}</p>
    <a href="/logout" class="btn" style="margin-top:20px; background:#e74c3c;">
        Déconnexion
    </a>
</div>
{% endblock %}
