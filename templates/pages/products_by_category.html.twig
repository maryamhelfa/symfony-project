{% extends 'base.html.twig' %}

{% block title %}Products{% endblock %}

{% block content %}
<h1>🛒 Products</h1>
<div class="grid">
{% for product in products %}
    <div class="card">
        <h3>{{ product.name }}</h3>
        <div class="price">{{ product.price }} DH</div>
        <a class="btn" href="/product/{{ product.id }}">View Details</a>
    </div>
{% else %}
    <p>No products found</p>
{% endfor %}
</div>
<a class="back-link" href="/categories">← Back to Categories</a>
{% endblock %}
