<!DOCTYPE html>
<html>
<head><title>Products</title></head>
<body>
<h1>Products</h1>
<ul>
{% for product in products %}
    <li>
        <a href="/product/{{ product.id }}">{{ product.name }}</a>
        - {{ product.price }} DH
    </li>
{% else %}
    <li>No products found</li>
{% endfor %}
</ul>
<a href="/categories">← Back to Categories</a>
</body>
</html>
