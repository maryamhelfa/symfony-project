{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block content %}
<div class="product-detail" style="max-width:450px; margin:0 auto;">
    <h1>🔐 Se connecter</h1>

    {% if error %}
        <div style="color:red; margin-bottom:15px; padding:10px; background:#ffe0e0; border-radius:6px;">
            Email ou mot de passe incorrect.
        </div>
    {% endif %}

    <form method="post">
        <div style="margin-bottom:15px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Email</label>
            <input type="email" name="_username" value="{{ last_username }}"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
        </div>
        <div style="margin-bottom:20px;">
            <label style="display:block; margin-bottom:5px; font-weight:bold;">Mot de passe</label>
            <input type="password" name="_password"
                   style="width:100%; padding:10px; border:1px solid #ddd; border-radius:6px;">
        </div>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
        <button type="submit" class="btn" style="width:100%; padding:12px;">
            Se connecter
        </button>
    </form>

    <p style="margin-top:20px; text-align:center;">
        Pas encore de compte ? <a href="/register">S'inscrire</a>
    </p>
</div>
{% endblock %}
