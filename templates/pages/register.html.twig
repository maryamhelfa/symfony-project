{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block content %}
<div class="product-detail" style="max-width:500px; margin:0 auto;">
    <h1>📝 Créer un compte</h1>

    {{ form_start(form) }}
        <div style="margin-bottom:15px;">
            {{ form_label(form.name) }}
            {{ form_widget(form.name, {'attr': {
                'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:5px;'
            }}) }}
            <div style="color:red;">{{ form_errors(form.name) }}</div>
        </div>

        <div style="margin-bottom:15px;">
            {{ form_label(form.email) }}
            {{ form_widget(form.email, {'attr': {
                'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:5px;'
            }}) }}
            <div style="color:red;">{{ form_errors(form.email) }}</div>
        </div>

        <div style="margin-bottom:15px;">
            {{ form_label(form.plainPassword.first) }}
            {{ form_widget(form.plainPassword.first, {'attr': {
                'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:5px;'
            }}) }}
            <div style="color:red;">{{ form_errors(form.plainPassword.first) }}</div>
        </div>

        <div style="margin-bottom:20px;">
            {{ form_label(form.plainPassword.second) }}
            {{ form_widget(form.plainPassword.second, {'attr': {
                'style': 'width:100%; padding:10px; border:1px solid #ddd; border-radius:6px; margin-top:5px;'
            }}) }}
            <div style="color:red;">{{ form_errors(form.plainPassword.second) }}</div>
        </div>

        <button type="submit" class="btn" style="width:100%; padding:12px;">
            S'inscrire
        </button>
    {{ form_end(form) }}

    <p style="margin-top:20px; text-align:center;">
        Déjà un compte ? <a href="/login">Se connecter</a>
    </p>
</div>
{% endblock %}
