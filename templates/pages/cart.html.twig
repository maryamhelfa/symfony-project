{% extends 'base.html.twig' %}

{% block title %}Mon Panier{% endblock %}

{% block content %}
<h1>🛒 Mon Panier</h1>

{% if cart.cartItems is empty %}
    <p>Votre panier est vide. <a href="/categories">Continuer les achats</a></p>
{% else %}
    <table style="width:100%; background:white; border-radius:10px; padding:20px;">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Prix</th>
                <th>Quantité</th>
                <th>Sous-total</th>
            </tr>
        </thead>
        <tbody>
        {% for item in cart.cartItems %}
            <tr>
                <td>{{ item.product.name }}</td>
                <td>{{ item.price }} DH</td>
                <td>{{ item.quantity }}</td>
                <td>{{ item.price * item.quantity }} DH</td>
            </tr>
        {% endfor %}
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3"><strong>Total</strong></td>
                <td><strong>{{ cart.total() }} DH</strong></td>
            </tr>
        </tfoot>
    </table>
    <a class="back-link" href="/categories">← Continuer les achats</a>
{% endif %}
{% endblock %}
