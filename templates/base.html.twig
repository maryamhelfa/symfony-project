<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}My Store{% endblock %}</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #f5f5f5; color: #333; }
        nav { background: #2c3e50; padding: 15px 30px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 10px; }
        nav a.brand { color: white; font-size: 22px; font-weight: bold; text-decoration: none; }
        nav .links a { color: #ccc; text-decoration: none; margin-left: 20px; }
        nav .links a:hover { color: white; }
        nav .links span { color: #2ecc71; margin-left: 20px; font-weight: bold; }
        .container { max-width: 1100px; margin: 30px auto; padding: 0 20px; }
        h1 { margin-bottom: 25px; color: #2c3e50; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
        .card { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); transition: transform 0.2s; }
        .card:hover { transform: translateY(-4px); }
        .card h3 { margin-bottom: 10px; color: #2c3e50; }
        .card .price { color: #e74c3c; font-weight: bold; font-size: 18px; margin-bottom: 15px; }
        .card a.btn { display: inline-block; background: #2c3e50; color: white; padding: 8px 16px; border-radius: 6px; text-decoration: none; font-size: 14px; }
        .card a.btn:hover { background: #e74c3c; }
        .btn { display: inline-block; background: #2c3e50; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; border: none; cursor: pointer; font-size: 15px; }
        .btn:hover { background: #e74c3c; }
        .back-link { margin-top: 25px; display: inline-block; color: #2c3e50; text-decoration: none; }
        .product-detail { background: white; border-radius: 10px; padding: 40px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .product-detail .price { color: #e74c3c; font-size: 24px; font-weight: bold; margin: 15px 0; }
        .product-detail .description { color: #666; line-height: 1.6; margin-bottom: 25px; }
    </style>
</head>
<body>
    <nav>
        <a class="brand" href="/">🛍️ My Store</a>
        <div class="links">
            <a href="/categories">Categories</a>
            <a href="/cart">🛒 Cart</a>
            {% if app.user %}
                <span>👋 Bienvenue, {{ app.user.name }}</span>
                <a href="/profile">Mon Profil</a>
                <a href="/logout" style="color:#e74c3c;">Déconnexion</a>
            {% else %}
                <a href="/login">Se connecter</a>
                <a href="/register">S'inscrire</a>
            {% endif %}
        </div>
    </nav>
    <div class="container">
        {% block content %}{% endblock %}
    </div>
</body>
</html>
